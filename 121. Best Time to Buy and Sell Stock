class Solution {
    public int maxProfit(int[] prices) {
        int profit = 0;
        int min = prices[0];
          
          for(int n=0;n<prices.length;n++)
          {
            min = Math.min(min,prices[n]);
            profit = Math.max(profit,prices[n] - min);
          }
          return profit;
    }
}
