class Solution {
    public int maxProfit(int[] prices) {
        int profit = 0;
        for(int a =0;a<prices.length;a++)
        {
            for(int b=a+1;b<prices.length;b++)
            {
                if(prices[b]-prices[a]>profit)
                {
                    profit = prices[b]-prices[a];
                }
            }
        }
        return profit;
    }
}
